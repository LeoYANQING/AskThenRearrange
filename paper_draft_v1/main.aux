\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textcolor {revcolor}{Three questioning design patterns extracted from HHI and formalized for robotic dialogue. Each pattern targets a different level of preference information. PS (Preference-Summarizing), observed in HHI, is operationalized as PI (Preference-Induction) in our system.}}}{11}{table.caption.6}\protected@file@percent }
\newlabel{tab:patterns}{{1}{11}{\rev {Three questioning design patterns extracted from HHI and formalized for robotic dialogue. Each pattern targets a different level of preference information. PS (Preference-Summarizing), observed in HHI, is operationalized as PI (Preference-Induction) in our system.}}{table.caption.6}{}}
