\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textcolor {revcolor}{Four questioning strategies, their questioning pattern composition, and example dialogue sequences generated by the system. The first three correspond to HHI patterns; HYB is an adaptive combination. AO = Action-Oriented, PE = Preference-Eliciting, PI = Preference-Induction.}}}{13}{table.caption.8}\protected@file@percent }
\newlabel{tab:strategies}{{2}{13}{\rev {Four questioning strategies, their questioning pattern composition, and example dialogue sequences generated by the system. The first three correspond to HHI patterns; HYB is an adaptive combination. AO = Action-Oriented, PE = Preference-Eliciting, PI = Preference-Induction.}}{table.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Budget allocation across four questioning strategies at $B{=}5$. Each cell represents one dialogue turn, colored by the questioning pattern used. DQ applies only AO throughout; UPF begins with PE to elicit category rules before switching to AO; PAR interleaves AO with PI after evidence accumulates; HYB selects adaptively among all three patterns. The annotation panel shows the resulting state $\mathcal  {A}^+$/$\mathcal  {P}^+$ after five turns for UPF versus DQ, illustrating why UPF generalizes better to unseen objects: it accumulates transferable category rules ($\mathcal  {P}^+$) rather than only object-specific actions ($\mathcal  {A}^+$).}}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:strategy-timeline}{{6}{13}{Budget allocation across four questioning strategies at $B{=}5$. Each cell represents one dialogue turn, colored by the questioning pattern used. DQ applies only AO throughout; UPF begins with PE to elicit category rules before switching to AO; PAR interleaves AO with PI after evidence accumulates; HYB selects adaptively among all three patterns. The annotation panel shows the resulting state $\mathcal {A}^+$/$\mathcal {P}^+$ after five turns for UPF versus DQ, illustrating why UPF generalizes better to unseen objects: it accumulates transferable category rules ($\mathcal {P}^+$) rather than only object-specific actions ($\mathcal {A}^+$)}{figure.caption.9}{}}
