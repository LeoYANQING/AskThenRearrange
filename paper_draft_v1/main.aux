\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textcolor {revcolor}{We study how questioning strategies affect robot learning of household preferences. Our work (1) identifies three distinct questioning patterns in human teaching, (2) formalizes them as questioning design patterns within a structured preference learning framework, and (3) quantifies their impact on placement accuracy through large-scale simulation, showing that top-down preference elicitation significantly outperforms item-by-item querying on novel objects.}}}{1}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:teaser}{{1}{1}{\rev {We study how questioning strategies affect robot learning of household preferences. Our work (1) identifies three distinct questioning patterns in human teaching, (2) formalizes them as questioning design patterns within a structured preference learning framework, and (3) quantifies their impact on placement accuracy through large-scale simulation, showing that top-down preference elicitation significantly outperforms item-by-item querying on novel objects.}}{figure.caption.1}{}}
